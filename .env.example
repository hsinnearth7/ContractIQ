# ContractIQ Configuration (CIQ_ prefix)

# --- OpenAI ---
CIQ_OPENAI_API_KEY=sk-your-key-here
CIQ_LLM_MODEL=gpt-4o
CIQ_EMBEDDING_MODEL=text-embedding-3-small
CIQ_LLM_TEMPERATURE=0.0
CIQ_LLM_MAX_TOKENS=2048

# --- Neo4j ---
CIQ_NEO4J_URI=bolt://localhost:7687
CIQ_NEO4J_USERNAME=neo4j
CIQ_NEO4J_PASSWORD=password
CIQ_NEO4J_DATABASE=neo4j

# --- Retrieval ---
CIQ_RETRIEVAL_TOP_K=20
CIQ_RERANK_TOP_K=5
CIQ_HYBRID_ALPHA=0.5

# --- Chunking ---
CIQ_CHUNK_STRATEGY=recursive
CIQ_CHUNK_SIZE=1000
CIQ_CHUNK_OVERLAP=200

# --- Logging ---
CIQ_LOG_LEVEL=INFO
